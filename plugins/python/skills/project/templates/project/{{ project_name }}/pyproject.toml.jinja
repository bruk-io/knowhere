[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ description }}"
requires-python = ">={{ python_version }}"
dependencies = [
    "click>=8.1.0",
{% if mcp_enabled %}
    "fastmcp>=3.0.0b1",
{% endif %}
{% if has_tui %}
    "textual>=3.0.0",
{% endif %}
]

[[project.authors]]
name = "{{ author_name }}"

[project.license]
text = "MIT"

{% if project_type != 'library' %}
[project.scripts]
{{ cli_command_name }} = "{{ package_name }}.presentation.cli.commands:cli"
{% endif %}

[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "pytest-cov>=4.1.0",
{% if mcp_enabled %}
    "pytest-asyncio>=0.23.0",
{% endif %}
    "ruff>=0.9.0",
    "mypy>=1.8.0",
]

[tool.ruff]
line-length = {{ line_length }}
target-version = "{{ target_version }}"

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W", "B", "C4", "UP"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"
skip-magic-trailing-comma = false
line-ending = "auto"

[tool.mypy]
python_version = "{{ python_version }}"
strict = true
warn_return_any = true
warn_unused_configs = true

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = "test_*.py"
{% if mcp_enabled %}
asyncio_mode = "auto"
{% endif %}

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["{{ package_name }}"]
