      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: "{{ go_version }}"

      - name: Install dependencies
        run: go mod download

      - name: Lint
        uses: golangci/golangci-lint-action@v6

      - name: Vet
        run: go vet ./...

      - name: Test
        run: go test -v -race ./...
