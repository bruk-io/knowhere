site_name: {{ project_name }}
{% if description %}
site_description: {{ description }}
{% endif %}
{% if author %}
site_author: {{ author }}
{% endif %}
{% if repo_url %}
repo_url: {{ repo_url }}
repo_name: {{ repo_url.split('/')[-2] }}/{{ repo_url.split('/')[-1] }}
edit_uri: edit/main/docs/
{% endif %}

theme:
  name: material
{% if nav_style == 'tabs' %}
  features:
    - navigation.tabs
    - navigation.tabs.sticky
    - navigation.sections
    - navigation.expand
    - navigation.top
    - search.suggest
    - search.highlight
    - content.code.copy
    - content.code.annotate
{% else %}
  features:
    - navigation.sections
    - navigation.expand
    - navigation.top
    - search.suggest
    - search.highlight
    - content.code.copy
    - content.code.annotate
{% endif %}
  palette:
    - scheme: default
      primary: indigo
      accent: indigo
      toggle:
        icon: material/brightness-7
        name: Switch to dark mode
    - scheme: slate
      primary: indigo
      accent: indigo
      toggle:
        icon: material/brightness-4
        name: Switch to light mode

plugins:
  - search
{% if enable_blog %}
  - blog
{% endif %}
{% if enable_api_docs %}
  - mkdocstrings:
      handlers:
        python:
          options:
            show_source: true
            show_root_heading: true
            members_order: source
{% endif %}

markdown_extensions:
  - pymdownx.highlight:
      anchor_linenums: true
  - pymdownx.superfences
  - pymdownx.tabbed:
      alternate_style: true
  - pymdownx.details
  - admonition
  - attr_list
  - md_in_html
  - toc:
      permalink: true

nav:
  - Home: index.md
  - Getting Started:
      - Installation: getting-started/installation.md
      - Quick Start: getting-started/quickstart.md
{% if enable_api_docs %}
  - API Reference: api/index.md
{% endif %}
{% if enable_blog %}
  - Blog:
      - blog/index.md
{% endif %}
