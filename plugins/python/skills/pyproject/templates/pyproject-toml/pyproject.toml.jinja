[project]
name = "{{ project_name }}"
version = "0.1.0"
{%- if description %}
description = "{{ description }}"
{%- endif %}
requires-python = ">={{ python_version }}"
{%- if project_type == 'service' %}
dependencies = [
    "uvicorn[standard]>=0.34.0",
]
{%- elif project_type == 'cli' %}
dependencies = [
    "click>=8.1.0",
]
{%- else %}
dependencies = []
{%- endif %}
{%- if author_name or author_email %}

[[project.authors]]
{%- if author_name %}
name = "{{ author_name }}"
{%- endif %}
{%- if author_email %}
email = "{{ author_email }}"
{%- endif %}
{%- endif %}
{%- if license %}

[project.license]
text = "{{ license }}"
{%- endif %}
{%- if project_type == 'cli' %}

[project.scripts]
{{ cli_command_name }} = "{{ project_name | replace('-', '_') }}.cli:main"
{%- endif %}

[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "pytest-cov>=4.1.0",
    "ruff>=0.9.0",
    "mypy>=1.8.0",
]

# Standard project interface
# These scripts provide a consistent interface across all projects.
# The same commands work in Docker containers (via entrypoint.sh) and locally (via uv run).
#
# Core:    uv run test | uv run lint | uv run check
{%- if project_type == 'service' %}
# Service: uv run serve | uv run dev
{%- elif project_type == 'library' %}
# Library: uv run build
{%- endif %}

[tool.uv.scripts]
test = "pytest"
lint = "ruff check ."
check = "uv run lint && uv run test"
{%- if project_type == 'service' %}
serve = "uvicorn {{ app_module }} --host 0.0.0.0 --port {{ port }}"
dev = "uvicorn {{ app_module }} --host 0.0.0.0 --port {{ port }} --reload"
{%- elif project_type == 'library' %}
build = "uv build"
{%- endif %}

[tool.ruff]
line-length = {{ line_length }}
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.format]
quote-style = "double"
indent-style = "space"
skip-magic-trailing-comma = false
line-ending = "auto"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["{{ project_name | replace('-', '_') }}"]
