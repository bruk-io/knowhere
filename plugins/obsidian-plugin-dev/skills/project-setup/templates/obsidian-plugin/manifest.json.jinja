{
	"id": "{{ plugin_id }}",
	"name": "{{ plugin_name }}",
	"version": "1.0.0",
	"minAppVersion": "{{ min_app_version }}",
{% if description %}
	"description": "{{ description }}",
{% endif %}
{% if author %}
	"author": "{{ author }}",
{% endif %}
{% if author_url %}
	"authorUrl": "{{ author_url }}",
{% endif %}
	"isDesktopOnly": {{ is_desktop_only | lower }}
}
