# syntax=docker/dockerfile:1

# ============================================================================
# Multi-target Dockerfile for {{ app_name }}
#
# Targets:
#   deps     - Dependency installation (base for all stages)
#   ci       - CI/testing environment (GitHub Actions: target: ci)
#   dev      - Development container (devcontainer: target: dev)
#   prod     - Production image (deploy artifact)
#
# Entrypoint commands:
#   test     - Run test suite
#   lint     - Run linter
#   check    - Run lint + test
{% if project_type == "service" %}
#   serve    - Start in production mode
#   dev      - Start with hot reload
{% elif project_type == "library" %}
#   build    - Build the package
{% endif %}
#   shell    - Interactive shell
#
# Usage:
#   docker build --target ci   -t {{ app_name }}:ci .
#   docker build --target dev  -t {{ app_name }}:dev .
#   docker build --target prod -t {{ app_name }}:prod .
#   docker run {{ app_name }}:ci test
# ============================================================================

# ---------------------------------------------------------------------------
# deps: Install dependencies
# ---------------------------------------------------------------------------
FROM python:{{ python_version }}-slim AS deps

{% if uses_uv %}
COPY --from=ghcr.io/astral-sh/uv:0.6 /uv /uvx /usr/local/bin/

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

WORKDIR /app

RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --frozen --no-install-project --no-dev
{% else %}
WORKDIR /app

COPY requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-deps -r requirements.txt
{% endif %}

# ---------------------------------------------------------------------------
# ci: Testing and CI
# ---------------------------------------------------------------------------
FROM deps AS ci

{% if uses_uv %}
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --frozen --no-install-project
{% else %}
COPY requirements-dev.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-deps -r requirements-dev.txt
{% endif %}

COPY . .
{% if uses_uv %}
RUN uv sync --frozen
{% endif %}

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
CMD ["test"]

# ---------------------------------------------------------------------------
# dev: Development container
# ---------------------------------------------------------------------------
FROM ci AS dev

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

EXPOSE {{ port }}

{% if project_type == "service" %}
CMD ["dev"]
{% else %}
CMD ["shell"]
{% endif %}

# ---------------------------------------------------------------------------
# prod: Production image
# ---------------------------------------------------------------------------
FROM python:{{ python_version }}-slim AS prod

RUN groupadd --system app && useradd --system --gid app app

WORKDIR /app

{% if uses_uv %}
COPY --from=deps /app/.venv /app/.venv
ENV PATH="/app/.venv/bin:$PATH"
{% else %}
COPY --from=deps /usr/local/lib/python{{ python_version }}/site-packages /usr/local/lib/python{{ python_version }}/site-packages
{% endif %}

COPY . .
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER app
EXPOSE {{ port }}

ENTRYPOINT ["/entrypoint.sh"]
{% if project_type == "service" %}
CMD ["serve"]
{% else %}
CMD ["shell"]
{% endif %}
